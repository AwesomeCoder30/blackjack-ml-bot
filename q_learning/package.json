{
    "name": "blackjack-q-learning",
    "version": "1.0.0",
    "description": "Q-learning Blackjack agent with web UI",
    "type": "module",
    "scripts": {
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:frontend": "vite build",
        "start": "node dist/backend/backend/index.js",
        "dev": "tsx watch src/backend/index.ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "supertest": "^6.3.4",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vitest": "^1.0.0",
        "tsx": "^4.7.0"
    },
    "dependencies": {
        "express": "^4.18.2"
    }
}